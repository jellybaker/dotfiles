layout {

    focus-ring {
        active-color   "#c4c9af"
        inactive-color "#131312"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#c4c9af"
        inactive-color "#131312"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#c4c9af"
        inactive-color "#1f2413"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#c4c9af80"
    }
}
