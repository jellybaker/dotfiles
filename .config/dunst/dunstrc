# Dunst notification daemon config — generated by matugen
# Template: ~/.config/matugen/templates/dunst.ini

[global]
    monitor     = 0
    follow      = keyboard

    # Geometry — (min, max) width; max height
    width           = (200, 500)
    height          = (0, 250)
    origin          = top-right
    offset          = (14, 14)
    scale           = 0
    notification_limit = 5

    # Appearance
    padding              = 14
    horizontal_padding   = 14
    text_icon_padding    = 12
    frame_width          = 1
    gap_size             = 8
    separator_height     = 1
    corner_radius        = 12

    # Typography
    font         = JetBrainsMono Nerd Font 11
    line_height  = 0
    markup       = full
    format       = "<b>%s</b>\n%b"
    alignment    = left
    vertical_alignment = center
    word_wrap    = yes
    ellipsize    = middle

    # Stacking
    stack_duplicates     = true
    hide_duplicate_count = false
    show_indicators      = true

    # Icons
    icon_position    = left
    min_icon_size    = 32
    max_icon_size    = 48
    icon_corner_radius = 6
    icon_path        = /usr/share/icons/Papirus-Dark/48x48/status:/usr/share/icons/Papirus-Dark/48x48/devices

    # Progress bar
    progress_bar                = true
    progress_bar_height         = 8
    progress_bar_frame_width    = 1
    progress_bar_min_width      = 200
    progress_bar_max_width      = 400
    progress_bar_corner_radius  = 4
    # progress bar fill uses primary color (frame_color comes from urgency section)
    highlight = "#cec6ab"

    # History
    sticky_history  = yes
    history_length  = 20
    show_age_threshold = 60

    # Actions
    dmenu   = /usr/sbin/fuzzel -d -p "dunst: "
    browser = /usr/bin/xdg-open
    always_run_script = true

    # Mouse
    mouse_left_click  = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

    # Default frame color (overridden per urgency below)
    frame_color    = "#93908c"
    separator_color = frame

    # Timeout sorting
    sort = urgency_descending
    idle_threshold = 0


# ── Urgency: Low ── subtle, informational ──────────────────────────────────────
[urgency_low]
    background  = "#211f1d"
    foreground  = "#cac6c1"
    frame_color = "#484643"
    timeout     = 4
    icon        = dialog-information

# ── Urgency: Normal ── standard notifications ──────────────────────────────────
[urgency_normal]
    background  = "#2b2a27"
    foreground  = "#e6e2dd"
    frame_color = "#cec6ab"
    timeout     = 8
    icon        = dialog-information

# ── Urgency: Critical ── errors, alerts (no auto-dismiss) ─────────────────────
[urgency_critical]
    background  = "#93000a"
    foreground  = "#ffdad6"
    frame_color = "#ffb4ab"
    timeout     = 0
    icon        = dialog-error
